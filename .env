# ─── Server ───────────────────────────────────────────────────────────────────
# Bind to 0.0.0.0 to allow same-WiFi phone access.
# Change to 127.0.0.1 to restrict to this machine only.
BIND_HOST=0.0.0.0
PORT=8000

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong random secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret

# Session duration in hours (default: 8)
SESSION_HOURS=8

# 32-character key used for AES-256 encryption of PAN numbers.
# Generate:  python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key-00

# ─── App ──────────────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
